# Client Environment Variables

# Backend API URL
# Development:
VITE_SERVER_URL=http://localhost:8080/api
# Production:
# VITE_SERVER_URL=https://your-backend-domain.com/api

# Socket Server URL (for real-time chat/battles)
# Development:
VITE_SOCKET_SERVER_URL=http://localhost:8080
# Production:
# VITE_SOCKET_SERVER_URL=https://your-backend-domain.com

# Judge0 API Key (for code execution)
VITE_JUDGE0_API_KEY=your_judge0_api_key

# Google Gemini API Key (for AI features)
VITE_GEMINI_API_KEY=your_gemini_api_key

# Note: For production deployment:
# 1. Update VITE_SERVER_URL to your production backend URL
# 2. Update VITE_SOCKET_SERVER_URL to your production backend URL (same domain, different protocol handling)
# 3. Ensure CORS is configured on backend to allow your production frontend domain
